# Example environment file. Copy to ./.env at the repo root and `chmod 600`,
# or run `python -m hyacine init` to generate it from the wizard.

# ---- Microsoft Graph / Entra ID ----
# Microsoft Graph PowerShell public client — works for any tenant without
# admin consent in most cases. Override only if your org requires a
# single-tenant registration.
HYACINE_GRAPH_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e
# "common" works for any tenant (multi-tenant). Replace with your tenant
# GUID for single-tenant apps.
HYACINE_GRAPH_TENANT_ID=common
HYACINE_GRAPH_SCOPES="User.Read Mail.Read Mail.Send Calendars.Read"

# ---- Claude Code (LLM) ----
# MUST be the OAuth token from `claude setup-token`, NOT an Anthropic API key.
# ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN must be UNSET in the invocation
# environment — they silently override OAuth and bill the Console account.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-replace-me

# ---- Monitoring (optional) ----
# Long random topic name from https://ntfy.sh — do not publish it.
HYACINE_NTFY_TOPIC=
# Healthchecks.io UUID — Hobbyist tier is free and sufficient.
HYACINE_HEALTHCHECKS_UUID=
