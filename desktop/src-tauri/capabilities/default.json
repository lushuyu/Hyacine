{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability grants for the Hyacine desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:allow-open-url",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "store:default",
    "dialog:default",
    "os:default",
    "process:default"
  ]
}
