# systemd user service — one-shot daily hyacine run, triggered by .timer.
# Install: ~/.config/systemd/user/hyacine-run.service
# Assumes the repo is cloned at ~/hyacine with `uv sync` run. Edit
# WorkingDirectory / EnvironmentFile / ExecStart if you keep it elsewhere.

[Unit]
Description=Hyacine pipeline run
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/hyacine
EnvironmentFile=%h/hyacine/.env
UnsetEnvironment=ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
# No Restart= on oneshot — the timer's Persistent=true handles missed runs.
ExecStart=%h/hyacine/.venv/bin/python -m hyacine.pipeline.run

# Same hardening profile as the web unit.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/hyacine/data %h/hyacine/prompts %h/hyacine/config
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
